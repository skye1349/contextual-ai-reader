{
  "name": "contextual-ai-reader",
  "version": "1.0.10",
  "description": "Multilingual AI reading companion for translation, contextual vocabulary, PDFs, and Markdown notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src",
    "build:dev-plugin": "npm run build && node scripts/build-dev.mjs",
    "install:dev-plugin": "npm run build:dev-plugin && node scripts/install-dev-plugin.mjs",
    "test:e2e": "wdio run ./wdio.conf.mts"
  },
  "keywords": [
    "obsidian",
    "codex",
    "translation",
    "multilingual",
    "reading",
    "vocabulary"
  ],
  "author": "Taoye",
  "license": "MIT",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.21",
    "@typescript-eslint/parser": "^8.64.0",
    "@wdio/cli": "^9.29.0",
    "@wdio/globals": "^9.29.0",
    "@wdio/local-runner": "^9.29.0",
    "@wdio/mocha-framework": "^9.29.0",
    "@wdio/spec-reporter": "^9.29.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "mocha": "^11.7.6",
    "obsidian": "^1.8.7",
    "obsidian-launcher": "^3.1.1",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1"
  }
}
