{
  "name": "contextual-ai-reader",
  "version": "1.0.0",
  "description": "AI reading companion for translation, contextual vocabulary, PDFs, YouTube transcripts, and Markdown notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "codex",
    "translation",
    "reading",
    "youtube",
    "vocabulary"
  ],
  "author": "Contextual AI Reader contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  }
}
